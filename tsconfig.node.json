  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "composite": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "build/vite/**/*.ts"]
}
