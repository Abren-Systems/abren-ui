{
  "name": "abren-erp-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "generate-types": "npx openapi-typescript http://localhost:8000/api/v1/openapi.json -o src/shared/api/generated.types.ts"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "pinia": "^2.3.0",
    "@primevue/core": "^4.3.0",
    "@primevue/themes": "^4.3.0",
    "primevue": "^4.3.0",
    "@tanstack/vue-query": "^5.65.0",
    "@tanstack/vue-form": "^1.28.0",
    "@tanstack/vue-table": "^8.21.0",
    "@tanstack/vue-virtual": "^3.13.0",
    "axios": "^1.7.0",
    "zod": "^3.24.0",
    "lucide-vue-next": "^0.474.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.0",
    "typescript": "~5.7.0",
    "@tsconfig/node22": "^22.0.0",
    "@vue/tsconfig": "^0.7.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss-primeui": "^0.5.0",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "typescript-eslint": "^8.22.0",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0",
    "@vue/test-utils": "^2.4.0",
    "jsdom": "^26.0.0",
    "@playwright/test": "^1.49.0",
    "openapi-typescript": "^7.6.0"
  }
}
