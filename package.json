{
  "name": "abren-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "vp lint . --fix",
    "format": "vp fmt src/",
    "generate": "node scripts/scaffold-module.js",
    "test:unit": "vp test",
    "test:unit:watch": "vp test --watch",
    "test:e2e": "playwright test",
    "generate-types": "npx openapi-typescript http://localhost:8000/api/v1/openapi.json -o src/shared/api/generated.types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/vue-form": "^1.29.0",
    "@tanstack/vue-query": "^5.99.2",
    "@tanstack/vue-table": "^8.21.3",
    "@tanstack/vue-virtual": "^3.13.24",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.15.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.474.0",
    "pinia": "^2.3.1",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-vue": "^9.33.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plus": "^0.1.18",
    "vitest": "~4.1.4",
    "vue-tsc": "^2.2.12"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,vue}": [
      "vp lint --fix"
