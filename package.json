{
  "name": "abren-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "lint": "vp lint . --fix",
    "format": "vp fmt src/",
    "generate": "node scripts/scaffold-module.js",
    "test:unit": "vp test",
    "test:unit:watch": "vp test --watch",
    "test:e2e": "playwright test",
    "generate-types": "npx openapi-typescript ../abren-api/openapi.json -o src/shared/api/generated.types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/vue-form": "^1.28.0",
    "@tanstack/vue-query": "^5.65.0",
    "@tanstack/vue-table": "^8.21.0",
    "@tanstack/vue-virtual": "^3.13.0",
    "@vueuse/core": "^12.0.0",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.474.0",
    "pinia": "^2.3.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.7.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.6.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.22.0",
    "vite": "^8.0.1",
    "vite-plus": "^0.1.13",
    "vitest": "4.1",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,vue}": [
      "vp lint --fix"
    ]
